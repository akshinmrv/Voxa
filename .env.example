# Copy to `.env` (which is gitignored) and fill in your keys.
# Voxa auto-loads `.env` on startup; real environment variables take precedence.

# LLM translation backends (only the one you use is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# OpenRouter — one key, many vendors (DeepSeek, Gemini, Llama…); use --translator openrouter
OPENROUTER_API_KEY=sk-or-...
