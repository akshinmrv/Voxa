# Voxa web — environment variables. Copy to .env.local for local dev, or set
# these in your host's dashboard for a public deploy. All are optional; the
# defaults below are what you get if a variable is unset.

# Build target. `local` (default) ships the full operator app. `public` replaces
# the operator app with a "run locally" notice — use it for the public landing.
NEXT_PUBLIC_TARGET=local

# Canonical site URL for SEO (canonical, hreflang, OpenGraph, sitemap, JSON-LD).
# Set this to your real domain before deploying the public landing.
NEXT_PUBLIC_SITE_URL=https://voxa.servoogle.com

# Base URL of the local `voxa serve` backend the operator app talks to.
NEXT_PUBLIC_VOXA_API=http://localhost:8000
