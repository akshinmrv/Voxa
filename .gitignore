# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/
venv/
.venv/

# Voxa working / output artifacts
*_work/
*.srt
voxa.log
state.json

# Media (input videos / generated audio are user data, not source)
*.mp4
*.mkv
*.mov
*.avi
*.wav
*.mp3

# ...but committed examples and demo assets are source
!examples/**
!docs/assets/**

# Secrets / environment
.env
*.key
*.pem

# Editor / OS / tooling
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Private working documents — kept on the maintainer's machine, never published.
# (Internal audits, phase planning, session continuity notes, commercial strategy.)
context.md
SESSION_CONTEXT.md
DESIGN_SYSTEM.md
ROADMAP.md
PROJECT_AUDIT.md
OPEN_SOURCE_AUDIT_AND_ROADMAP_AZ.md
AI_PROVIDER_AND_SPEECH_CONTROL_STRATEGY_AZ.md
SAAS_MASTER_STRATEGY.md
SPEECH_SYNC_STRATEGY.md
NEXT_GENERATION_SPEECH_PIPELINE_STRATEGY.md

# Installed agent skills (ui-ux-pro-max etc.) — local tooling, not project source
.agents/
skills-lock.json

# `voxa serve` runtime workspace — uploads and per-job output, never committed.
.voxa_serve/

# Local dubbing test artifacts (source video, per-language outputs, work dirs).
# The *.mp4 rule above already covers test1.mp4 and *_dubbed_*.mp4.
*_work/

# ...but the landing's demo/showcase media ARE committed, so re-include them.
!web/public/demo/*.mp4
!web/public/tts-samples/*.mp3
